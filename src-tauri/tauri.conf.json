{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bike Potato",
  "version": "0.1.0",
  "identifier": "com.jack-develops.lost-green",
  "build": {
    "frontendDist": "../src-elixir/priv/static"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "lost_green_backend"
    ]
    ,
    "macOS": {
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
